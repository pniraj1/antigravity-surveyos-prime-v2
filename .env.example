# Firebase Configuration
# Copy this file to .env.local and fill in your own values for local development

# Public Firebase config (safe to commit)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=surveyos-v2-antigravity.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=surveyos-v2-antigravity
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=surveyos-v2-antigravity.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=926682149516
NEXT_PUBLIC_FIREBASE_APP_ID=1:926682149516:web:7a4b8de9b48e2ebf4dc1a9

# Firebase API Key (rotate in Firebase Console, keep secret, use CI/CD secrets for production)
# Get your key from: https://console.firebase.google.com/project/surveyos-v2-antigravity/settings/apikeys
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here

# Google Drive API (public client ID, safe to commit)
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=926682149516-eqq2j1eah869ng6ohlcpn3g54d8dibot.apps.googleusercontent.com
