{
  "hosting": [
    {
      "target": "motorsurveyos",
      "public": "out",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        { "source": "/landing",  "destination": "/", "type": 301 },
        { "source": "/landing/", "destination": "/", "type": 301 }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "surveyos-v2-antigravity",
      "public": "out",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        { "source": "/landing",  "destination": "/", "type": 301 },
        { "source": "/landing/", "destination": "/", "type": 301 }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
