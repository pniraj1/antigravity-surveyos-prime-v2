rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Role-based admin check — reads isAdmin flag from the user's own profile.
    // Any user can be promoted to admin by setting isAdmin: true in their profile.
    // Replaces old hardcoded UID approach.
    function isAdmin() {
      // Hardcoded bypass for owner account (pniraj.india@gmail.com).
      // TODO: Verify isAdmin:true is set on this UID's Firestore profile doc,
      // then remove this line so all admin access flows through the profile flag.
      return request.auth != null && (
        request.auth.uid == 'QCgRlZdGF3etljVitH8xq3KsTqB2' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/profile/current) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/current).data.isAdmin == true
        )
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // AI Configuration — admin-only (contains master API keys)
    match /ai_config/routing {
      allow read, write: if isAdmin();
    }

    // New signup notifications — users create their own entry on first login,
    // only admins can read or manage them
    match /newSignups/{uid} {
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow read, update, delete: if isAdmin();
    }

    // Collection Group query support for Admin Panel
    match /{path=**}/profile/{docId} {
      allow read, write: if isAdmin();
    }

    // User-specific data — each user accesses only their own data
    match /users/{userId} {
      // 1. Profile collection gets special protection to prevent users making themselves admin
      match /profile/{docId} {
        allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
        
        allow create: if isAdmin() || (
          isSignedIn() && request.auth.uid == userId && 
          (!request.resource.data.keys().hasAny(['isAdmin']) || request.resource.data.isAdmin == false)
        );
        
        allow update: if isAdmin() || (
          isSignedIn() && request.auth.uid == userId && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin'])
        );
        
        allow delete: if isAdmin();
      }
      
      // 2. All other user data (claims, photos, etc) is fully writable by the user
      match /{collectionId}/{document=**} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId && collectionId != 'profile');
      }
    }

    // Legacy support
    match /claims/{claimId} {
      allow read, write: if false; // Migrated to users/{uid}/claims
    }
  }
}
